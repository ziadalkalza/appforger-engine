# code_sources: see project-control/code_sources/code-source-registry.yaml
# runtime_env: values below are local/cloud runtime references
# appforge_can_index_this_file: false
# DO NOT COMMIT. This file contains local/private runtime and access values.
# AppForger local/private configuration.
# Copy this file to local-only/.env.local and fill values locally.
# Do not commit or index local-only/.env.local.

# Runtime storage: Postgres / SQL
POSTGRES_URL=
APPFORGE_POSTGRES_HOST=localhost
APPFORGE_POSTGRES_PORT=55432
APPFORGE_POSTGRES_DB=appforge
APPFORGE_POSTGRES_USER=appforge
APPFORGE_POSTGRES_PASSWORD=appforge

# Runtime storage: Qdrant / vector
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
APPFORGE_QDRANT_PORT=6333

# Runtime storage: Neo4j / graph
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=appforge-change-me
APPFORGE_NEO4J_HTTP_PORT=7474
APPFORGE_NEO4J_BOLT_PORT=7687

# Git providers
GITHUB_TOKEN=
GITLAB_TOKEN=

# Bitbucket Cloud / Data Center
BITBUCKET_CLOUD_USERNAME=
BITBUCKET_CLOUD_API_TOKEN=
BITBUCKET_CLOUD_WORKSPACE=
BITBUCKET_DATA_CENTER_BASE_URL=
BITBUCKET_DATA_CENTER_TOKEN=
BITBUCKET_DATA_CENTER_PROJECT_KEY=

# Confluence Cloud / Data Center
CONFLUENCE_CLOUD_BASE_URL=
CONFLUENCE_CLOUD_EMAIL=
CONFLUENCE_CLOUD_API_TOKEN=
CONFLUENCE_CLOUD_SCOPED_TOKEN=
CONFLUENCE_DATA_CENTER_BASE_URL=
CONFLUENCE_DATA_CENTER_PAT=

# Optional Supabase runtime/profile
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
