name: AppForge Validation

on:
  workflow_dispatch:
  pull_request:
    paths:
      - 'project-control/**'
      - 'appforge-engine/**'

jobs:
  validate-appforge:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - name: Run AppForge automation layer validation
        run: python appforge-engine/VALIDATION/validate_automation_layer.py
